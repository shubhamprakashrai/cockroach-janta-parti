# CJP environment template — copy to .env.local for local dev
# Add the same vars in Vercel Project Settings → Environment Variables for production

# ----- Formspree (join form submissions) -----
# Get a form ID from https://formspree.io (free tier: 50 submissions/month).
# Endpoint becomes: https://formspree.io/f/$NEXT_PUBLIC_FORMSPREE_ID
NEXT_PUBLIC_FORMSPREE_ID=

# ----- Firebase (real member counter, meme likes, blog comments, admin uploads) -----
# Get these from Firebase Console → Project Settings → Your Apps → SDK setup and configuration.
# See FIREBASE-SETUP.md for full step-by-step.
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# ----- Admin passcode (for /admin upload panel) -----
# Anyone with this passcode can publish blogs / reels / news.
# CHANGE THIS in Vercel and locally; do not share publicly.
NEXT_PUBLIC_ADMIN_PASSCODE=
